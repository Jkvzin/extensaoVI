# Arquivo de variáveis de ambiente do Supabase
# ATENÇÃO: NÃO COLOQUE AS CHAVES REAIS NESTE ARQUIVO E NÃO COMITE O .env COM DADOS REAIS!
# Copie este arquivo para .env e preencha com as informações do seu projeto.

# URL do seu projeto no Supabase (ex: https://xxxxx.supabase.co)
SUPABASE_URL=sua_url_aqui

# Chave pública anon para usar no frontend
SUPABASE_ANON_KEY=sua_anon_key_aqui

# Chave secreta (service role). NUNCA exponha esta chave no frontend (js). Apenas em ambientes server-side.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
